# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...
# SUPABASE_JWT_SECRET is no longer required for production.
# JWT verification uses Supabase JWKS (ES256) automatically.
# Set this only if using MFA partial tokens or generating test tokens locally.
# SUPABASE_JWT_SECRET=your-jwt-secret

# Email
RESEND_API_KEY=re_...

# App
CORS_ORIGIN=http://localhost:3000
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
MFA_ENCRYPTION_KEY=some-32-character-encryption-key-
SENTRY_DSN=your-sentry-dsn-here

# VAPID Keys for Web Push (optional)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
