{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/v1/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/sw.js",
      "dest": "frontend/sw.js"
    },
    {
      "src": "/favicon.ico",
      "dest": "frontend/assets/favicons/favicon.ico"
    },
    {
      "src": "/apple-touch-icon.png",
      "dest": "frontend/assets/favicons/favicon-180x180.png"
    },
    {
      "src": "/site.webmanifest",
      "dest": "frontend/site.webmanifest"
    },
    {
      "src": "/forgot-password.html",
      "dest": "frontend/forgot-password.html"
    },
    {
      "src": "/reset-password.html",
      "dest": "frontend/reset-password.html"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}

